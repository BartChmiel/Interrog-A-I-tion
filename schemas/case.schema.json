{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interrogaition.local/schemas/case.schema.json",
  "title": "Case",
  "type": "object",
  "required": ["id", "title", "created_at", "topics"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "topics": {
      "type": "array",
      "items": { "$ref": "#/$defs/topic" }
    }
  },
  "$defs": {
    "topic": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    }
  }
}
