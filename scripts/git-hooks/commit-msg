#!/bin/sh
# Final guard: strip any Cursor co-author trailer before the commit is created.
COMMIT_MSG_FILE=$1

if [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

tmp_file="${COMMIT_MSG_FILE}.tmp"
grep -v -i 'Co-authored-by: Cursor' "$COMMIT_MSG_FILE" > "$tmp_file"
mv "$tmp_file" "$COMMIT_MSG_FILE"

exit 0
