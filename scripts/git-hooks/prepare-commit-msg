#!/bin/sh
# Remove Cursor agent co-author trailers from every commit message.
COMMIT_MSG_FILE=$1

if [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

tmp_file="${COMMIT_MSG_FILE}.tmp"
grep -v -i 'Co-authored-by: Cursor <cursoragent@cursor.com>' "$COMMIT_MSG_FILE" | grep -v -i 'Co-authored-by: Cursor <' > "$tmp_file"
mv "$tmp_file" "$COMMIT_MSG_FILE"

exit 0
