# Developer-only local AI setup for InterrogA(I)tion.
# Default supervisor demo stays deterministic when these variables are not set.

$env:INTERROGAITION_MODEL_PROVIDER = "ollama"
$env:INTERROGAITION_OLLAMA_MODEL = "llama3.1:8b"
$env:INTERROGAITION_ENABLE_REAL_MODEL = "1"
$env:INTERROGAITION_ENABLE_LIVE_MODEL_OUTPUT = "1"

# Optional:
# $env:INTERROGAITION_OLLAMA_BASE_URL = "http://127.0.0.1:11434"

Write-Host "Local AI developer mode enabled for this shell."
Write-Host "Start Ollama, then restart the backend from backend/:"
Write-Host "  python -m interrogaition.api.app"
